# Copy this file to ".streamlit/secrets.toml" and paste your real key.
# secrets.toml is gitignored — never commit it.
#
# Get a key at https://aistudio.google.com  →  "Get API key"
# Either name works (GEMINI_API_KEY is preferred):

GEMINI_API_KEY = "paste-your-gemini-key-here"
# GOOGLE_API_KEY = "paste-your-gemini-key-here"

# Set to true to surface verbose status messages in the UI.
# SHOW_STATUS = false

# ── History storage (optional) ──────────────────────────────────────────────
# Leave these unset → DocFill stores history in a local SQLite file (data/history.db).
# Set them → DocFill stores history in Google Sheets via your Apps Script Web App
# (permanent in the cloud AND local). See apps_script/Code.gs for setup.
# GSHEET_WEBAPP_URL = "https://script.google.com/macros/s/XXXXXXXX/exec"
# GSHEET_TOKEN      = "the-same-long-random-token-you-set-in-Code.gs"
